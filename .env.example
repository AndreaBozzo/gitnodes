# GitNodes hosted/OAuth environment
# Local `gitnodes serve` usually needs no .env: it discovers the repository and
# branch from Git and reuses `gh auth`. Copy this file for a hosted multi-user
# deployment and fill in these three values.

# GitHub OAuth App credentials.
# Register one at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Default repository, using either an organization or personal account owner.
TARGET_GITHUB_REPOSITORY=your-owner/your-repository

# Optional overrides.
#TARGET_GITHUB_BRANCH=main
#BRAND_NAME=GitNodes
#BRAND_ORG_LABEL=your-owner

# With TARGET_GITHUB_REPOSITORY, login is org-less by default. Set this to an
# organization to restrict who may sign in. Repository access is always
# checked separately against live GitHub permissions.
#GITHUB_LOGIN_ORG=your-organization

# Sessions use SQLite at data/sessions.db. A private encryption key is generated
# once at data/session.key. Mount data/ persistently in production.
#SESSION_DB_URL=sqlite://data/sessions.db
#SESSION_ENCRYPTION_KEY_FILE=data/session.key
#SESSION_ENCRYPTION_KEY=

# Webhooks are optional and disabled in production until a secret is set.
#WEBHOOK_SECRET=

# Server-side GitHub credentials, used by the webhook handler when no user
# session is present. Only needed when webhook sync is enabled. Pick one:
#
#   A. GitHub App (recommended). Install the App on the target org/repo with
#      Contents: Read & write, Pull requests: Read & write, Issues: Read &
#      write, Metadata: Read. Tokens auto-rotate hourly.
#GITHUB_APP_ID=
#GITHUB_APP_INSTALLATION_ID=
# Inline the PEM as a single-line string with literal `\n` between lines:
#GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----\n"
# Or point at a file on disk (preferred for secret mounts):
#GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem
#
#   B. Fine-grained PAT fallback. Used when GITHUB_APP_* is unset, or when the
#      App-token mint fails. Must have the same repo permissions as above.
#GITHUB_TOKEN=

# Background-job tuning and retention.
#PENDING_SYNC_INTERVAL_SECS=60
#RETENTION_INTERVAL_SECS=86400
#AUDIT_RETENTION_DAYS=90

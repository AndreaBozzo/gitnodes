# Brain UI — Environment Variables
# Copy to .env and fill in your values.

# GitHub OAuth App credentials.
# Register one at: https://github.com/organizations/<your-org>/settings/applications
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Target repository the app reads from and writes to.
# TARGET_GITHUB_ORG is also the org required for login (membership check).
TARGET_GITHUB_ORG=Dritara-Digital
TARGET_GITHUB_REPO=Brain
TARGET_GITHUB_BRANCH=main

# User-facing branding. `BRAND_NAME` appears in the header and page title;
# `BRAND_ORG_LABEL` appears in access-denied copy (typically matches the org).
BRAND_NAME=Dritara Brain
BRAND_ORG_LABEL=Dritara-Digital

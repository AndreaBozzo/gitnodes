{
  "name": "gitnodes-styles",
  "private": true,
  "version": "0.1.0",
  "description": "Build-time Tailwind pipeline for GitNodes. Runtime is pure Rust.",
  "scripts": {
    "build:css": "tailwindcss -i crates/gitnodes-app/style/tailwind.css -o crates/gitnodes-app/style/main.css --minify",
    "watch:css": "tailwindcss -i crates/gitnodes-app/style/tailwind.css -o crates/gitnodes-app/style/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "tailwindcss": "^4.3.2"
  }
}

{
  "name": "brain_ui-styles",
  "private": true,
  "version": "0.3.0",
  "description": "Build-time Tailwind pipeline for brain_ui. Runtime is pure Rust.",
  "scripts": {
    "build:css": "tailwindcss -i crates/brain-app/style/tailwind.css -o crates/brain-app/style/main.css --minify",
    "watch:css": "tailwindcss -i crates/brain-app/style/tailwind.css -o crates/brain-app/style/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "daisyui": "^4.12.24",
    "tailwindcss": "^3.4.17"
  }
}
